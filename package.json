{
  "name": "usb-audio-scanner",
  "version": "1.0.1",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --windows"
  },
  "devDependencies": {
    "electron": "^13.6.9",
    "electron-builder": "^22.14.13"
  },
  "build": {
    "appId": "com.usb.audioscanner",
    "productName": "USBAudioScanner",
    "icon": "icon.ico",
    "win": {
      "icon": "icon.ico",
      "target": [
        "portable"
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "icon.ico"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
